# ────────────────────────────────────────────────
# HomeworkAI — Cấu hình môi trường
# Copy file này thành .env rồi điền giá trị thật
# ────────────────────────────────────────────────

# Flask secret key (tạo ngẫu nhiên cho production)
SECRET_KEY=your-super-secret-key-change-this

# ── Gemini API (Google AI Studio) ──
# Lấy tại: https://aistudio.google.com/app/apikey
AI_API_KEY=your-gemini-api-key-here

# URL endpoint Gemini (đổi model tại đây nếu cần)
# Các model miễn phí: gemini-1.5-flash, gemini-1.5-flash-8b, gemini-2.0-flash-exp
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent